# Required
SUPABASE_DB_URL=
JWT_SECRET=replace-me

# Optional pool tuning
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10

# Existing app settings
EXPOSE_DEBUG_OTP=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=saatdin-admin

# CORS for deployed frontend (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Fraud scoring settings
FRAUD_SCORING_ENABLED=true
FRAUD_MODEL_PATH=backend/models/fraud/fraud_iforest_latest.joblib
FRAUD_ANOMALY_THRESHOLD=-0.05
FRAUD_FAIL_OPEN=true
FRAUD_METRICS_LOG_EVERY_N=25

# Optional external API keys
WAQI_API_KEY=
TOMTOM_API_KEY=
NEWS_API_KEY=

# Ambiguous fraud LLM fallback (LangGraph path)
